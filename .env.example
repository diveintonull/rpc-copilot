# "real" runs LangGraph + RAG + the configured LLM. Use "demo" only for the
# small offline fixture used by deployment tests.
APP_RUN_MODE=real
APP_HOST_PORT=8000
QDRANT_HOST_PORT=6333

# Local Python uses localhost. Compose overrides this with http://qdrant:6333.
QDRANT_URL=http://localhost:6333

# OpenAI-compatible generation endpoint used by real mode.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_VALIDATE_ENTAILMENT=true

# Use "modelscope" where Hugging Face is unavailable. Compose persists the
# Linux container cache in the model_cache named volume.
EMBED_MODEL_SOURCE=modelscope
RERANK_MODEL_SOURCE=modelscope
MODEL_DEVICE=cpu
